<Window x:Class="AppLauncher.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dialog"
        Width="560"
        MinWidth="460"
        MaxWidth="640"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Text"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="DialogCardBrush" Color="#FCFCFD" />
        <SolidColorBrush x:Key="DialogStrokeBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="DialogPrimaryTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="DialogSecondaryTextBrush" Color="#5B6472" />
        <SolidColorBrush x:Key="DialogAccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="DialogAccentFillBrush" Color="#E8F3FF" />
        <SolidColorBrush x:Key="DialogSuccessBrush" Color="#067647" />
        <SolidColorBrush x:Key="DialogSuccessFillBrush" Color="#E8F7EF" />
        <SolidColorBrush x:Key="DialogWarningBrush" Color="#B54708" />
        <SolidColorBrush x:Key="DialogWarningFillBrush" Color="#FFF3E5" />
        <SolidColorBrush x:Key="DialogDangerBrush" Color="#B42318" />
        <SolidColorBrush x:Key="DialogDangerFillBrush" Color="#FEE4E2" />

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource DialogStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource DialogPrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="18,11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="ButtonTranslate" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="ButtonShadow"
                                                  BlurRadius="18"
                                                  Direction="270"
                                                  ShadowDepth="0"
                                                  Color="#1F000000"
                                                  Opacity="0.14" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.015"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.015"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-1"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.14"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.015"
                                                         Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.015"
                                                         Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-1"
                                                         Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"
                                                         Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.985"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.985"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="1"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.08"
                                                         Duration="0:0:0.06" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="LostMouseCapture">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.14"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Border Background="{StaticResource DialogCardBrush}" CornerRadius="28" BorderBrush="{StaticResource DialogStrokeBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="36"
                                  Direction="270"
                                  ShadowDepth="0"
                                  Color="#26000000"
                                  Opacity="0.22" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="AccentStripBorder" Grid.Row="0" CornerRadius="28,28,0,0" />

                <Grid Grid.Row="1" Margin="24,22,24,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="ToneBadgeBorder"
                            Padding="10,5"
                            CornerRadius="999"
                            HorizontalAlignment="Left">
                        <TextBlock x:Name="ToneBadgeTextBlock"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Style="{StaticResource DialogCloseButtonStyle}"
                            BorderBrush="{StaticResource DialogStrokeBrush}"
                            Foreground="{StaticResource DialogSecondaryTextBrush}"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <TextBlock Text="X" FontSize="13" FontWeight="Bold" />
                    </Button>
                </Grid>

                <Grid Grid.Row="2" Margin="24,18,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="88" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconHostBorder"
                            Width="72"
                            Height="72"
                            CornerRadius="24"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left">
                        <TextBlock x:Name="IconTextBlock"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="34"
                                   FontWeight="Bold" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="4,2,0,0">
                        <TextBlock x:Name="TitleTextBlock"
                                   FontFamily="Segoe UI Variable Display"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DialogPrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <Border Margin="0,16,0,0"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource DialogStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="280">
                                <TextBlock x:Name="MessageTextBlock"
                                           Foreground="{StaticResource DialogSecondaryTextBrush}"
                                           FontSize="14"
                                           LineHeight="22"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="3" Margin="24,22,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="SecondaryActionButton"
                            Grid.Column="1"
                            MinWidth="130"
                            Style="{StaticResource DialogButtonStyle}"
                            Click="SecondaryActionButton_Click" />
                    <Button x:Name="PrimaryActionButton"
                            Grid.Column="3"
                            MinWidth="150"
                            Style="{StaticResource DialogButtonStyle}"
                            Click="PrimaryActionButton_Click" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
