<Window x:Class="AppLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="App Launcher"
        Icon="image/icon-app.ico"
        Height="820"
        Width="1320"
        MinHeight="760"
        MinWidth="1120"
        Background="#F3F3F3"
        FontFamily="Segoe UI Variable Text">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#F9F9F9" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="SubtleStrokeBrush" Color="#F0F2F4" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5B6472" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F6CBD" />
        <SolidColorBrush x:Key="AccentFillBrush" Color="#E8F3FF" />
        <SolidColorBrush x:Key="DangerFillBrush" Color="#FEE4E2" />
        <SolidColorBrush x:Key="ChipBrush" Color="#EEF1F5" />

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFFFFF" />
            <GradientStop Offset="0.65" Color="#F4F8FD" />
            <GradientStop Offset="1" Color="#E9F2FC" />
        </LinearGradientBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="InputHostStyle" TargetType="Border">
            <Setter Property="Background" Value="#FDFDFD" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="1" />
        </Style>

        <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="42" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="ButtonTranslate" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="ButtonShadow"
                                                  BlurRadius="18"
                                                  Direction="270"
                                                  ShadowDepth="0"
                                                  Color="#1F000000"
                                                  Opacity="0.14" />
                            </Border.Effect>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.015"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.015"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-1"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.14"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.015"
                                                         Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.015"
                                                         Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="-1"
                                                         Duration="0:0:0.08" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.2"
                                                         Duration="0:0:0.08" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.985"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.985"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="1"
                                                         Duration="0:0:0.06" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.08"
                                                         Duration="0:0:0.06" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="LostMouseCapture">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.12" />
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.14"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaneListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="#FBFBFC"
                                BorderBrush="{StaticResource SubtleStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F6F9FC" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentFillBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#8FBEEA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ProfileItemTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                    <Border Background="{StaticResource ChipBrush}" CornerRadius="999" Padding="8,3" Margin="0,0,8,6">
                        <TextBlock Text="{Binding AppCountLabel}" FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" />
                    </Border>
                    <Border Background="{StaticResource ChipBrush}" CornerRadius="999" Padding="8,3" Margin="0,0,0,6">
                        <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}" Text="{Binding BackendStatusLabel}" />
                    </Border>
                </WrapPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AppItemTemplate">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding Path}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="App Launcher" FontFamily="Segoe UI Variable Display" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="Fluent-style launcher built for Windows 11." Margin="0,6,0,0" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="2" Margin="0,20,0,20">
                    <Border Background="#FFFFFF" BorderBrush="{StaticResource SubtleStrokeBrush}" BorderThickness="1" CornerRadius="16" Margin="0,0,8,0" Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="ProfilesCountTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="0" />
                            <TextBlock Text="Profiles" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="{StaticResource SubtleStrokeBrush}" BorderThickness="1" CornerRadius="16" Margin="8,0,0,0" Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="LibraryCountTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Text="0" />
                            <TextBlock Text="App library" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="2" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AddProfileButton" Content="Add Profile" Style="{StaticResource BaseButtonStyle}" Click="AddProfile_Click" />
                    <Button x:Name="DeleteProfileButton" Grid.Column="2" Content="Delete" MinWidth="104" Background="{StaticResource DangerFillBrush}" BorderBrush="#F7C1BD" Foreground="#B42318" Style="{StaticResource BaseButtonStyle}" Click="DeleteProfile_Click" />
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Text="Profiles" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                        <TextBlock Text="Pick a workspace on the left, then edit and launch it on the right." Margin="0,6,0,0" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ListBox x:Name="ProfilesListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource ProfileItemTemplate}"
                             ItemContainerStyle="{StaticResource PaneListBoxItemStyle}"
                             SelectionChanged="ProfilesListBox_SelectionChanged" />
                </Grid>

                <Border Grid.Row="4" Margin="0,18,0,0" Background="#FFFFFF" BorderBrush="{StaticResource SubtleStrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="14">
                    <TextBlock Text="Save an app in any profile, then add it quickly to other profiles from the shared library." FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Background="{StaticResource HeroBrush}" BorderBrush="#D8E5F3" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Selected Workspace" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedProfileHeaderTextBlock" Margin="0,10,0,0" Text="No profile selected" FontFamily="Segoe UI Variable Display" FontSize="34" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock x:Name="SelectedProfileSubtitleTextBlock" Margin="0,8,0,0" MaxWidth="660" Text="Create or select a profile to manage apps and backend tasks." FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,16,0,0">
                                <Border Background="#FFFFFF" CornerRadius="999" Padding="10,6" Margin="0,0,10,0">
                                    <TextBlock x:Name="AppCountTextBlock" Text="0 apps ready" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                                <Border Background="#FFFFFF" CornerRadius="999" Padding="10,6">
                                    <TextBlock x:Name="BackendStatusTextBlock" Text="No backend task" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <Button x:Name="StartSelectedProfileButton"
                                Grid.Column="1"
                                Height="48"
                                VerticalAlignment="Center"
                                Content="Start Selected Profile"
                                Background="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                Foreground="White"
                                Style="{StaticResource BaseButtonStyle}"
                                Click="StartSelectedProfile_Click" />
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Profile Details" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Give each workspace a clear name so it is easy to identify at a glance." Margin="0,6,0,20" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="Profile name" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                            <Border Style="{StaticResource InputHostStyle}">
                                <TextBox x:Name="ProfileNameTextBox" Style="{StaticResource FluentTextBoxStyle}" />
                            </Border>
                            <Button x:Name="SaveProfileNameButton" Content="Save Name" Width="132" Margin="0,16,0,0" HorizontalAlignment="Left" Style="{StaticResource BaseButtonStyle}" Click="SaveProfileName_Click" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Backend Task" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Save a folder and command if this profile also needs to run a backend service." Margin="0,6,0,20" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="Folder" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource InputHostStyle}">
                                    <TextBox x:Name="BackendFolderTextBox" Style="{StaticResource FluentTextBoxStyle}" />
                                </Border>
                                <Button x:Name="BrowseBackendFolderButton" Grid.Column="2" Content="Browse" MinWidth="110" Style="{StaticResource BaseButtonStyle}" Click="BrowseBackendFolder_Click" />
                            </Grid>
                            <TextBlock Text="Command" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                            <Border Style="{StaticResource InputHostStyle}">
                                <TextBox x:Name="BackendCommandTextBox" Style="{StaticResource FluentTextBoxStyle}" />
                            </Border>
                            <Button x:Name="SaveBackendButton" Content="Save Backend" Width="146" Margin="0,16,0,0" HorizontalAlignment="Left" Style="{StaticResource BaseButtonStyle}" Click="SaveBackend_Click" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Apps In Profile" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                        <TextBlock Text="Combine apps from the shared library with brand-new apps inside the same profile." Margin="0,6,0,20" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource InputHostStyle}">
                                <ComboBox x:Name="ExistingAppsComboBox"
                                          Style="{StaticResource FluentComboBoxStyle}"
                                          ItemTemplate="{StaticResource AppItemTemplate}"
                                          SelectionChanged="ExistingAppsComboBox_SelectionChanged" />
                            </Border>
                            <Button x:Name="AddExistingAppButton" Grid.Column="2" Content="Add Existing" MinWidth="124" Style="{StaticResource BaseButtonStyle}" Click="AddExistingApp_Click" />
                            <Button x:Name="RemoveSelectedAppButton" Grid.Column="4" Content="Remove Selected" MinWidth="144" Background="{StaticResource DangerFillBrush}" BorderBrush="#F7C1BD" Foreground="#B42318" Style="{StaticResource BaseButtonStyle}" Click="RemoveSelectedApp_Click" />
                        </Grid>

                        <ListBox x:Name="ProfileAppsListBox"
                                 Height="220"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemTemplate="{StaticResource AppItemTemplate}"
                                 ItemContainerStyle="{StaticResource PaneListBoxItemStyle}"
                                 SelectionChanged="ProfileAppsListBox_SelectionChanged" />

                        <Border Margin="0,20,0,0" Background="#FFFFFF" BorderBrush="{StaticResource SubtleStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Add New App" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBlock Text="Enter the path to the .exe file and an optional display name if you want a custom label." Margin="0,6,0,18" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Display name" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <Border Style="{StaticResource InputHostStyle}">
                                            <TextBox x:Name="NewAppNameTextBox" Style="{StaticResource FluentTextBoxStyle}" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="App path" Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryTextBrush}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource InputHostStyle}">
                                                <TextBox x:Name="NewAppPathTextBox" Style="{StaticResource FluentTextBoxStyle}" />
                                            </Border>
                                            <Button x:Name="BrowseAppPathButton" Grid.Column="2" Content="Browse" MinWidth="110" Style="{StaticResource BaseButtonStyle}" Click="BrowseAppPath_Click" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <Button x:Name="AddNewAppButton" Content="Add New App" Width="132" Margin="0,18,0,0" HorizontalAlignment="Left" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" Foreground="White" Style="{StaticResource BaseButtonStyle}" Click="AddNewApp_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
